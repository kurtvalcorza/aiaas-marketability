# AIaaS Marketability Chatbot - Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# REQUIRED: Google AI API Key
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# This is required for the chatbot to work with Google's Gemini 2.5 Flash model
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here

# =============================================================================
# OPTIONAL: Qualitative enrichment pass
# =============================================================================
# After each interview is stored, a second structured LLM pass extracts
# research-grade fields (themes, quantified pains, reconciliation audit,
# evidence-based shadow ratings, tag suggestions) into extra columns. It is
# best-effort and never blocks a submission. Reuses GOOGLE_GENERATIVE_AI_API_KEY
# and runs on the Neon backend only. Set ENRICHMENT_ENABLED=false to turn it off;
# leave the others blank for the defaults (gemini-2.5-flash, 12000 ms timeout).
ENRICHMENT_ENABLED=
ENRICHMENT_MODEL=
ENRICHMENT_TIMEOUT_MS=

# =============================================================================
# STORAGE: Neon PostgreSQL (primary)
# =============================================================================
# 1. Create a free project at https://neon.tech
# 2. Run schema.sql once in the Neon SQL Editor to create the
#    aiaas_market_analysis table and the aggregate views
# 3. Copy the connection string from the Neon dashboard and paste it below
#
# If not set (and no Google Sheets webhook is set), the app will work but
# won't save interviews
DATABASE_URL=

# Selects the storage backend: "neon" or "google_sheets".
# If unset, the app auto-detects: Neon when DATABASE_URL is set,
# otherwise Google Sheets when GOOGLE_SHEETS_WEBHOOK_URL is set.
STORAGE_PROVIDER=

# =============================================================================
# STORAGE: Google Sheets Integration (alternative backend)
# =============================================================================
# If you want to collect interviews in Google Sheets:
# 1. Create a Google Sheet with these headers (in this exact column order):
#    Timestamp, Segment, Overlay, Route, Organization Type, Current Work Type,
#    AI Maturity, AI Work, Main Problem, Need Tags, Competitors, Friction Tags,
#    Use Case Tags, Cost Barrier (C), Technical Complexity (T),
#    Localization Gap (L), UVP Resonance (U), DVI, Interpretation,
#    Likelihood To Try, First-Use Pathway, Timeframe, Adoption Blockers,
#    Contact Consent, Contact Name, Contact Email, Summary, Conversation History
# 2. Go to Extensions -> Apps Script and add the doPost function (see README.md)
# 3. Deploy as Web App (Execute as: Me, Access: Anyone)
# 4. Copy the Web App URL and paste it below
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional: shared secret for HMAC-signing the Google Sheets webhook payload.
# Must match the SIGNING_SECRET in your Apps Script if you enable verification.
WEBHOOK_SIGNING_SECRET=

# =============================================================================
# RESEARCHER DASHBOARD: shared-password gate
# =============================================================================
# Protects the /dashboard route (aggregate DVI charts + CSV export). The public
# survey stays open; only the dashboard requires this password. Set a long,
# random value. Rotating it instantly signs out all existing dashboard sessions
# (the password doubles as the session signing key).
# If unset, the dashboard is unreachable (fails closed).
DASHBOARD_PASSWORD=

# =============================================================================
# RATE LIMITING: Vercel KV (recommended for production)
# =============================================================================
# Rate limiting (30 chat req/min, 5 submissions/5 min) uses an in-memory store by
# default. On serverless that store is PER-INSTANCE and resets on cold start, so the
# effective limit is higher than nominal. Set both vars below to switch to a shared
# Redis-backed limiter (Vercel KV) for accurate, distributed limits. If unset, the
# app automatically falls back to in-memory — no error.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# =============================================================================
# Development Notes
# =============================================================================
# - For local development, create .env.local (not tracked by git)
# - For production (Vercel), add these in the Vercel dashboard under Settings -> Environment Variables
# - The GOOGLE_SHEETS_WEBHOOK_URL is optional - the app gracefully handles its absence
